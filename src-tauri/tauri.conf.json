{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Submit PDF",
  "version": "0.1.0",
  "identifier": "com.submitpdf.desktop",
  "build": {
    "frontendDist": "../pdf"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Submit PDF",
        "width": 1280,
        "height": 860,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      { "ext": ["pdf"], "name": "PDF-Dokument", "description": "PDF", "role": "Editor" },
      { "ext": ["png", "jpg", "jpeg"], "name": "Bild", "description": "Bild", "role": "Editor" }
    ]
  }
}
